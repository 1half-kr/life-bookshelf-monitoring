global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  # Prometheus 자기 자신 모니터링
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  # 모니터링 서버 시스템 메트릭 (같은 docker network → 컨테이너명으로 접근)
  - job_name: 'node_monitoring'
    static_configs:
      - targets: ['node_exporter:9100']
        labels:
          server: 'monitoring'

  # Spring Boot 서버 시스템 메트릭
  - job_name: 'node_springboot'
    static_configs:
      - targets: ['{{ hostvars["springboot-server"]["ansible_host"] }}:9100']
        labels:
          server: 'springboot'

  # FastAPI 서버 시스템 메트릭
  - job_name: 'node_fastapi'
    static_configs:
      - targets: ['{{ hostvars["fastapi-server"]["ansible_host"] }}:9100']
        labels:
          server: 'fastapi'

  # 모니터링 서버 컨테이너 메트릭 (같은 docker network → 컨테이너명으로 접근)
  - job_name: 'cadvisor_monitoring'
    static_configs:
      - targets: ['cadvisor:8080']
        labels:
          server: 'monitoring'

  # Spring Boot 서버 컨테이너 메트릭
  - job_name: 'cadvisor_springboot'
    static_configs:
      - targets: ['{{ hostvars["springboot-server"]["ansible_host"] }}:9080']
        labels:
          server: 'springboot'

  # FastAPI 서버 컨테이너 메트릭
  - job_name: 'cadvisor_fastapi'
    static_configs:
      - targets: ['{{ hostvars["fastapi-server"]["ansible_host"] }}:9080']
        labels:
          server: 'fastapi'

  # 애플리케이션 헬스 체크 (Blackbox Exporter HTTP probe)
  - job_name: 'health_check'
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      - targets:
          - 'http://{{ hostvars["springboot-server"]["ansible_host"] }}:8080/health'
          - 'http://{{ hostvars["fastapi-server"]["ansible_host"] }}:3000/health'
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox_exporter:9115

  # Spring Boot 애플리케이션 메트릭 (actuator/prometheus 노출 필요)
  - job_name: 'app_springboot'
    metrics_path: '/actuator/prometheus'
    static_configs:
      - targets: ['{{ hostvars["springboot-server"]["ansible_host"] }}:8080']
        labels:
          server: 'springboot'

  # FastAPI 애플리케이션 메트릭 (prometheus_fastapi_instrumentator 등 노출 필요)
  - job_name: 'app_fastapi'
    static_configs:
      - targets: ['{{ hostvars["fastapi-server"]["ansible_host"] }}:8000']
        labels:
          server: 'fastapi'
